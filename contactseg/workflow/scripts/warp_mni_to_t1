import ants

def warp_mni_to_t1(atlas_img, t1_img, inverse_warp, affine, output_img):

    atlas=ants.image_read(atlas_img)
    t1 = ants.image_read(t1_img)

    warped_atlas = ants.apply_transforms(
        fixed=t1,
        moving=atlas,
        transformlist=[inverse_warp, affine],
        interpolator="nearestNeighbor"
    )

    ants.image_write(warped_atlas, output_img)

    if __name__ == "__main__":
        warp_mni_to_t1(
            atlas_img=snakemake.input.atlas_img,
            t1_img=snakemake.input.t1_img,
            inverse_warp=snakemake.input.inverse_warp,
            affine=snakemake.input.affine,
            output_img=snakemake.output.img,
        )
